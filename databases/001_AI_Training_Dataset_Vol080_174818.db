Section 4: Coding Tasks

Example 4.1

User

Write a two-sum function in Python.
AI Response
def two_sum(nums, target):
seen = {}
for i, n in enumerate(nums):
if target - n in seen: return (seen[target-n], i)
seen[n] = i

print(two_sum([2,7,11,15], 9)) # (0,1)

Example 4.2

User

Write a Python function to parse a URL into components.
AI Response
from urllib.parse import urlparse

def parse_url(url):
p = urlparse(url)
return {"scheme":p.scheme,"host":p.netloc,"path":p.path,"query":p.query}

print(parse_url("https://example.com/page?q=1"))

Example 4.3

User

Write a Python quicksort implementation.
AI Response
def quicksort(arr):
if len(arr) <= 1: return arr
p = arr[len(arr)//2]
return quicksort([x for x in arr if x < p]) + \
[x for x in arr if x == p] + \
quicksort([x for x in arr if x > p])

Example 4.4

User

Write a deep clone function in JavaScript.
AI Response
function deepClone(obj) {
if (obj === null || typeof obj !== "object") return obj;
if (Array.isArray(obj)) return obj.map(deepClone);
return Object.fromEntries(
Object.entries(obj).map(([k,v]) => [k, deepClone(v)])
);
}

Example 4.5

User



Write a Python function to find the longest word in a string.
AI Response
def longest_word(s):
words = s.split()
return max(words, key=len) if words else ""

print(longest_word("The quick brown fox")) # "quick"

Example 4.6

User

Write a Python function to group dicts by a key.
AI Response
from collections import defaultdict

def group_by(items, key):
g = defaultdict(list)
for item in items: g[item[key]].append(item)
return dict(g)

Example 4.7

User

Write a Python function to check balanced parentheses.
AI Response
def is_balanced(s):
stack = []
pairs = {")":"(", "]":"[", "}":"{"}
for c in s:
if c in "([{": stack.append(c)
elif c in pairs:
if not stack or stack[-1] != pairs[c]: return False
stack.pop()
return len(stack) == 0

print(is_balanced("({[]})")) # True

