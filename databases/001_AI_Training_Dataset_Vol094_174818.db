Section 4: Coding Tasks

Example 4.1

User

Write a Python function to find duplicate elements in a list.
AI Response
def find_duplicates(lst):
seen, dupes = set(), set()
for x in lst:
if x in seen: dupes.add(x)
else: seen.add(x)
return list(dupes)

print(find_duplicates([1,2,3,2,4,3,5])) # [2,3]

Example 4.2

User

Write a two-sum function in Python.
AI Response
def two_sum(nums, target):
seen = {}
for i, n in enumerate(nums):
if target - n in seen: return (seen[target-n], i)
seen[n] = i

print(two_sum([2,7,11,15], 9)) # (0,1)

Example 4.3

User

Write a Python quicksort implementation.
AI Response
def quicksort(arr):
if len(arr) <= 1: return arr
p = arr[len(arr)//2]
return quicksort([x for x in arr if x < p]) + \
[x for x in arr if x == p] + \
quicksort([x for x in arr if x > p])

Example 4.4

User

Write a Python decorator to time functions.
AI Response
import time, functools

def timer(func):
@functools.wraps(func)
def wrapper(*args, **kwargs):
t = time.perf_counter()
result = func(*args, **kwargs)
print(f"{func.__name__}: {time.perf_counter()-t:.4f}s")
return result



return wrapper

Example 4.5

User

Write a Python Caesar cipher function.
AI Response
def caesar(text, shift):
result = []
for c in text:
if c.isalpha():
base = ord("A") if c.isupper() else ord("a")
result.append(chr((ord(c) - base + shift) % 26 + base))
else:
result.append(c)
return "".join(result)

print(caesar("Hello", 3)) # "Khoor"

Example 4.6

User

Write a Python word frequency counter.
AI Response
from collections import Counter

def word_freq(text):
return dict(Counter(text.lower().split()))

print(word_freq("the cat sat on the mat"))

Example 4.7

User

Write a Python async URL fetcher.
AI Response
import asyncio, aiohttp

async def fetch(url):
async with aiohttp.ClientSession() as s:
async with s.get(url) as r:
return await r.text()

result = asyncio.run(fetch("https://example.com"))

