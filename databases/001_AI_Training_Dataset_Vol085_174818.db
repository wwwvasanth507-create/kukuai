Example 4.2

User

Write a Python function to convert a list of tuples to a dictionary.
AI Response
def tuples_to_dict(lst):
return dict(lst)

print(tuples_to_dict([("a",1),("b",2)])) # {"a":1,"b":2}

Example 4.3

User

Write a Python function to check if a number is prime.
AI Response
def is_prime(n: int) -> bool:
if n < 2: return False
for i in range(2, int(n**0.5) + 1):
if n % i == 0: return False
return True

print(is_prime(17)) # True

Example 4.4

User

Write a Python function to check if two strings are anagrams.
AI Response
def are_anagrams(a, b):
return sorted(a.lower()) == sorted(b.lower())

print(are_anagrams("listen","silent")) # True

Example 4.5

User

Write a Python function to merge two sorted lists.
AI Response
def merge_sorted(a, b):
res, i, j = [], 0, 0



while i < len(a) and j < len(b):
if a[i] <= b[j]: res.append(a[i]); i += 1
else: res.append(b[j]); j += 1
return res + a[i:] + b[j:]

