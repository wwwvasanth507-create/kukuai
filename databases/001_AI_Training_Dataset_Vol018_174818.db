Section 4: Coding Tasks

Example 4.1

User

Write a Python Stack class.
AI Response
class Stack:
def __init__(self): self._items = []
def push(self, item): self._items.append(item)
def pop(self): return self._items.pop()
def peek(self): return self._items[-1]
def is_empty(self): return len(self._items) == 0

Example 4.2

User

Write a two-sum function in Python.
AI Response
def two_sum(nums, target):
seen = {}
for i, n in enumerate(nums):
if target - n in seen: return (seen[target-n], i)
seen[n] = i

print(two_sum([2,7,11,15], 9)) # (0,1)

Example 4.3

User

Write a Python LRU cache implementation.
AI Response
from collections import OrderedDict

class LRUCache:
def __init__(self, cap): self.cap = cap; self.cache = OrderedDict()
def get(self, key):
if key not in self.cache: return -1
self.cache.move_to_end(key); return self.cache[key]
def put(self, key, val):
if key in self.cache: self.cache.move_to_end(key)
self.cache[key] = val
if len(self.cache) > self.cap: self.cache.popitem(last=False)

Example 4.4

User

Write a Python context manager for a timer.
AI Response
import time
from contextlib import contextmanager

@contextmanager
def timer(label=""):
start = time.perf_counter()



yield
print(f"{label}: {time.perf_counter()-start:.4f}s")

with timer("my block"):
sum(range(1_000_000))

Example 4.5

User

Write a deep clone function in JavaScript.
AI Response
function deepClone(obj) {
if (obj === null || typeof obj !== "object") return obj;
if (Array.isArray(obj)) return obj.map(deepClone);
return Object.fromEntries(
Object.entries(obj).map(([k,v]) => [k, deepClone(v)])
);
}

Example 4.6

User

Write a Python quicksort implementation.
AI Response
def quicksort(arr):
if len(arr) <= 1: return arr
p = arr[len(arr)//2]
return quicksort([x for x in arr if x < p]) + \
[x for x in arr if x == p] + \
quicksort([x for x in arr if x > p])

Example 4.7

User

Write a Python function to group dicts by a key.
AI Response
from collections import defaultdict

def group_by(items, key):
g = defaultdict(list)
for item in items: g[item[key]].append(item)
return dict(g)

Example 4.8

User

Write a Python Caesar cipher function.
AI Response
def caesar(text, shift):
result = []
for c in text:
if c.isalpha():
base = ord("A") if c.isupper() else ord("a")
result.append(chr((ord(c) - base + shift) % 26 + base))
else:
result.append(c)



return "".join(result)

print(caesar("Hello", 3)) # "Khoor"

