Section 4: Coding Tasks

Example 4.1

User

Write a Python quicksort implementation.
AI Response
def quicksort(arr):
if len(arr) <= 1: return arr
p = arr[len(arr)//2]
return quicksort([x for x in arr if x < p]) + \
[x for x in arr if x == p] + \
quicksort([x for x in arr if x > p])

Example 4.2

User

Write a Python context manager for a timer.
AI Response
import time
from contextlib import contextmanager

@contextmanager
def timer(label=""):
start = time.perf_counter()
yield
print(f"{label}: {time.perf_counter()-start:.4f}s")

with timer("my block"):
sum(range(1_000_000))

Example 4.3

User

Write a Python Caesar cipher function.
AI Response
def caesar(text, shift):
result = []
for c in text:
if c.isalpha():
base = ord("A") if c.isupper() else ord("a")
result.append(chr((ord(c) - base + shift) % 26 + base))
else:
result.append(c)
return "".join(result)

print(caesar("Hello", 3)) # "Khoor"

Example 4.4

User

Write a Python function to compute the nth Fibonacci number using memoization.
AI Response
from functools import lru_cache



@lru_cache(maxsize=None)
def fib(n):
if n < 2: return n
return fib(n-1) + fib(n-2)

print(fib(50)) # 12586269025

