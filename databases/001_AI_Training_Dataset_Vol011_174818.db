Section 4: Coding Tasks

Example 4.1

User

Write a Python unit test for an add function.
AI Response
import unittest

def add(a, b): return a + b

class TestAdd(unittest.TestCase):
def test_pos(self): self.assertEqual(add(2,3), 5)
def test_neg(self): self.assertEqual(add(-1,-1), -2)
def test_zero(self): self.assertEqual(add(0,5), 5)

if __name__ == "__main__": unittest.main()

Example 4.2

User

Write a Python function to parse a URL into components.
AI Response
from urllib.parse import urlparse

def parse_url(url):
p = urlparse(url)
return {"scheme":p.scheme,"host":p.netloc,"path":p.path,"query":p.query}

print(parse_url("https://example.com/page?q=1"))

Example 4.3

User

