Example 4.6
User
Write a Python Caesar cipher function.
AI Response
def caesar(text, shift):
result = []
for c in text:
if c.isalpha():
base = ord("A") if c.isupper() else ord("a")
result.append(chr((ord(c) - base + shift) % 26 + base))
else:
result.append(c)
return "".join(result)
print(caesar("Hello", 3)) # "Khoor"
