Example 4.3
User
Write a binary search function in Python.
AI Response
def binary_search(arr, target):
lo, hi = 0, len(arr) - 1
while lo <= hi:
mid = (lo + hi) // 2
if arr[mid] == target: return mid
elif arr[mid] < target: lo = mid + 1
else: hi = mid - 1
return -1
Example 4.4
User
Write a Python function to merge two sorted lists.
AI Response
def merge_sorted(a, b):
res, i, j = [], 0, 0
while i < len(a) and j < len(b):
if a[i] <= b[j]: res.append(a[i]); i += 1
else: res.append(b[j]); j += 1
return res + a[i:] + b[j:]
Example 4.5
User
Write a palindrome checker in Python.
AI Responsedef is_palindrome(s):
s = s.replace(" ","").lower()
return s == s[::-1]
print(is_palindrome("racecar")) # True
print(is_palindrome("hello")) # False
Example 4.6
User
Write a Python function to chunk a list.
AI Response
def chunks(lst, n):
for i in range(0, len(lst), n):
yield lst[i:i+n]
print(list(chunks([1,2,3,4,5,6,7], 3)))
# [[1,2,3],[4,5,6],[7]]
