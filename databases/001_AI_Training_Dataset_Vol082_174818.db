Section 4: Coding Tasks

Example 4.1

User

Write a Python function to find duplicate elements in a list.
AI Response
def find_duplicates(lst):
seen, dupes = set(), set()
for x in lst:
if x in seen: dupes.add(x)
else: seen.add(x)
return list(dupes)

print(find_duplicates([1,2,3,2,4,3,5])) # [2,3]

Example 4.2

User

Write a Python function to flatten a nested list.
AI Response
def flatten(lst):
result = []
for item in lst:
if isinstance(item, list):
result.extend(flatten(item))
else:
result.append(item)
return result

print(flatten([1, [2, [3, 4]]])) # [1, 2, 3, 4]

Example 4.3

User

Write Python to remove list duplicates preserving order.
AI Response
def unique(lst):
seen = set()
return [x for x in lst if not (x in seen or seen.add(x))]

print(unique([1,2,1,3,2,4])) # [1,2,3,4]

Example 4.4

User

Write a Python email validator using regex.
AI Response
import re

def valid_email(email):
return bool(re.match(r"^[\w.%+-]+@[\w.-]+\.[a-zA-Z]{2,}$", email))

print(valid_email("user@example.com")) # True
print(valid_email("bad@")) # False



Example 4.5

User

Write a Python function to merge two sorted lists.
AI Response
def merge_sorted(a, b):
res, i, j = [], 0, 0
while i < len(a) and j < len(b):
if a[i] <= b[j]: res.append(a[i]); i += 1
else: res.append(b[j]); j += 1
return res + a[i:] + b[j:]

Example 4.6

User

Write a Python Stack class.
AI Response
class Stack:
def __init__(self): self._items = []
def push(self, item): self._items.append(item)
def pop(self): return self._items.pop()
def peek(self): return self._items[-1]
def is_empty(self): return len(self._items) == 0

Example 4.7

User

Write a deep clone function in JavaScript.
AI Response
function deepClone(obj) {
if (obj === null || typeof obj !== "object") return obj;
if (Array.isArray(obj)) return obj.map(deepClone);
return Object.fromEntries(
Object.entries(obj).map(([k,v]) => [k, deepClone(v)])
);
}

