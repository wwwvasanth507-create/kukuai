Section 4: Coding Tasks

Example 4.1

User

Write a Python email validator using regex.
AI Response
import re

def valid_email(email):
return bool(re.match(r"^[\w.%+-]+@[\w.-]+\.[a-zA-Z]{2,}$", email))

print(valid_email("user@example.com")) # True
print(valid_email("bad@")) # False

Example 4.2

User

Write a Python decorator to time functions.
AI Response
import time, functools

def timer(func):
@functools.wraps(func)
def wrapper(*args, **kwargs):
t = time.perf_counter()
result = func(*args, **kwargs)
print(f"{func.__name__}: {time.perf_counter()-t:.4f}s")
return result
return wrapper

Example 4.3

User

Write a palindrome checker in Python.
AI Response
def is_palindrome(s):
s = s.replace(" ","").lower()
return s == s[::-1]

print(is_palindrome("racecar")) # True
print(is_palindrome("hello")) # False

Example 4.4

User

Write a Python async URL fetcher.
AI Response
import asyncio, aiohttp

async def fetch(url):
async with aiohttp.ClientSession() as s:
async with s.get(url) as r:
return await r.text()



result = asyncio.run(fetch("https://example.com"))

