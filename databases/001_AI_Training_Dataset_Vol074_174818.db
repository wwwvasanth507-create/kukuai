Example 4.1

User

Write a minimal Flask REST API.
AI Response
from flask import Flask, jsonify
app = Flask(__name__)

users = [{"id":1,"name":"Alice"},{"id":2,"name":"Bob"}]

@app.route("/users")
def get_users(): return jsonify(users)

if __name__ == "__main__": app.run(debug=True)

Example 4.2

User

Write a Python email validator using regex.
AI Response
import re

def valid_email(email):
return bool(re.match(r"^[\w.%+-]+@[\w.-]+\.[a-zA-Z]{2,}$", email))

print(valid_email("user@example.com")) # True
print(valid_email("bad@")) # False

Example 4.3

User

Write a two-sum function in Python.
AI Response
def two_sum(nums, target):
seen = {}
for i, n in enumerate(nums):
if target - n in seen: return (seen[target-n], i)
seen[n] = i

print(two_sum([2,7,11,15], 9)) # (0,1)

Example 4.4

User

Write a Python async URL fetcher.
AI Response
import asyncio, aiohttp

async def fetch(url):
async with aiohttp.ClientSession() as s:
async with s.get(url) as r:
return await r.text()



result = asyncio.run(fetch("https://example.com"))

Example 4.5

User

Write a Python function to find the intersection of two lists.
AI Response
def intersection(a, b):
return list(set(a) & set(b))

print(intersection([1,2,3,4],[2,4,6])) # [2,4]

Example 4.6

User

Write a React counter component.
AI Response
import { useState } from "react";

export default function Counter() {
const [count, setCount] = useState(0);
return (
<div>
<h2>{count}</h2>
<button onClick={() => setCount(c => c+1)}>+</button>
<button onClick={() => setCount(c => c-1)}>-</button>
</div>
);
}

Example 4.7

User

Write a Python function to check balanced parentheses.
AI Response
def is_balanced(s):
stack = []
pairs = {")":"(", "]":"[", "}":"{"}
for c in s:
if c in "([{": stack.append(c)
elif c in pairs:
if not stack or stack[-1] != pairs[c]: return False
stack.pop()
return len(stack) == 0

print(is_balanced("({[]})")) # True

Example 4.8

User

Write a Python function to parse a URL into components.
AI Response
from urllib.parse import urlparse

def parse_url(url):
p = urlparse(url)



return {"scheme":p.scheme,"host":p.netloc,"path":p.path,"query":p.query}

print(parse_url("https://example.com/page?q=1"))

