Section 4: Coding Tasks

Example 4.1

User

Write a Python quicksort implementation.
AI Response
def quicksort(arr):
if len(arr) <= 1: return arr
p = arr[len(arr)//2]
return quicksort([x for x in arr if x < p]) + \
[x for x in arr if x == p] + \
quicksort([x for x in arr if x > p])

Example 4.2

User

Write a two-sum function in Python.
AI Response
def two_sum(nums, target):
seen = {}
for i, n in enumerate(nums):
if target - n in seen: return (seen[target-n], i)
seen[n] = i

print(two_sum([2,7,11,15], 9)) # (0,1)

Example 4.3

User

Write Python to remove list duplicates preserving order.
AI Response
def unique(lst):
seen = set()
return [x for x in lst if not (x in seen or seen.add(x))]

print(unique([1,2,1,3,2,4])) # [1,2,3,4]

Example 4.4

User

Write a Python function to check balanced parentheses.
AI Response
def is_balanced(s):
stack = []
pairs = {")":"(", "]":"[", "}":"{"}
for c in s:
if c in "([{": stack.append(c)
elif c in pairs:
if not stack or stack[-1] != pairs[c]: return False
stack.pop()
return len(stack) == 0

print(is_balanced("({[]})")) # True

Example 4.5



User

Write a Python email validator using regex.
AI Response
import re

def valid_email(email):
return bool(re.match(r"^[\w.%+-]+@[\w.-]+\.[a-zA-Z]{2,}$", email))

print(valid_email("user@example.com")) # True
print(valid_email("bad@")) # False

Example 4.6

User

Write a Python Caesar cipher function.
AI Response
def caesar(text, shift):
result = []
for c in text:
if c.isalpha():
base = ord("A") if c.isupper() else ord("a")
result.append(chr((ord(c) - base + shift) % 26 + base))
else:
result.append(c)
return "".join(result)

print(caesar("Hello", 3)) # "Khoor"

