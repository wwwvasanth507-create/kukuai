Section 4: Coding Tasks

Example 4.1

User

Write a binary search function in Python.
AI Response
def binary_search(arr, target):
lo, hi = 0, len(arr) - 1
while lo <= hi:
mid = (lo + hi) // 2
if arr[mid] == target: return mid
elif arr[mid] < target: lo = mid + 1
else: hi = mid - 1
return -1

Example 4.2

User

Write a palindrome checker in Python.
AI Response
def is_palindrome(s):
s = s.replace(" ","").lower()
return s == s[::-1]

print(is_palindrome("racecar")) # True
print(is_palindrome("hello")) # False

Example 4.3

User

Write a Python quicksort implementation.
AI Response
def quicksort(arr):
if len(arr) <= 1: return arr
p = arr[len(arr)//2]
return quicksort([x for x in arr if x < p]) + \
[x for x in arr if x == p] + \
quicksort([x for x in arr if x > p])

Example 4.4

User

Write a Python decorator to time functions.
AI Response
import time, functools

def timer(func):
@functools.wraps(func)
def wrapper(*args, **kwargs):
t = time.perf_counter()
result = func(*args, **kwargs)
print(f"{func.__name__}: {time.perf_counter()-t:.4f}s")
return result
return wrapper



Example 4.5

User

Write a Python function to check if a number is prime.
AI Response
def is_prime(n: int) -> bool:
if n < 2: return False
for i in range(2, int(n**0.5) + 1):
if n % i == 0: return False
return True

print(is_prime(17)) # True

Example 4.6

User

Write a Python function to convert a list of tuples to a dictionary.
AI Response
def tuples_to_dict(lst):
return dict(lst)

print(tuples_to_dict([("a",1),("b",2)])) # {"a":1,"b":2}

Example 4.7

User

Write a Python unit test for an add function.
AI Response
import unittest

def add(a, b): return a + b

class TestAdd(unittest.TestCase):
def test_pos(self): self.assertEqual(add(2,3), 5)
def test_neg(self): self.assertEqual(add(-1,-1), -2)
def test_zero(self): self.assertEqual(add(0,5), 5)

if __name__ == "__main__": unittest.main()

Example 4.8

User

Write a Python context manager for a timer.
AI Response
import time
from contextlib import contextmanager

@contextmanager
def timer(label=""):
start = time.perf_counter()
yield
print(f"{label}: {time.perf_counter()-start:.4f}s")

with timer("my block"):
sum(range(1_000_000))

